{
  "functions": {
    "api/*.ts": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/themes_feed",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=86400, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/themes/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, immutable" }
      ]
    }
  ]
}
